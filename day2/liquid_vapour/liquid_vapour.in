# #####################################################################
#  DAY 2 - PART 2 : liquid-vapour slab (free-surface LJ)
#  A single-component Lennard-Jones liquid slab, centred in a longW
#  fully-periodic box (slab normal = z), so its two exposed faces relax
#  into liquid-vapour interfaces. One run feeds both Part-2 exercises:
#    (1) the z density profile + the diagonal pressure tensor -> surface
#        tension gamma  (analyse_liquid_vapour.py)
#    (2) the trajectory -> the intrinsic (capillary-wave) surface
#        (intrinsic_surface.py), with -var dump 1
#
#  Run one case:               lmp -in liquid_vapour.in
#  with varying temperature    lmp -in liquid_vapour.in -var T 1.0
#  for orientation/intrinsic: add  -var dump 1
#  for the pressure tensor:   add  -var localstress 1
# #####################################################################

# ---- parameters (override any with -var NAME value) ----
variable T       index 0.85    # temperature (T* < Tc* so a liquid slab coexists with vapour).
variable rho_l   index 0.7     # seed liquid density. follow the phase diagram with rho_v
variable rho_v   index 0.05    # seed vapour density
variable rcut    index 2.5     # LJ cutoff (sigma). rcut changes gamma
variable Lx_t    index 10.0    # lateral box target (sigma)
variable Ly_t    index 10.0
variable Lz_t    index 90.0    # long axis = slab normal: slab + two vapour gaps
variable tslab   index 20.0    # initial liquid-slab thickness (sigma), centred in z
variable bin     index 0.5     # z-profile bin width (sigma)
variable dt      index 0.005   # timestep
variable tdamp   index 1.0     # Nose-Hoover damping (tau)
variable nevery  index 100     # output frequency
variable nequil  index 10000   # equilibration steps
variable nprod   index 10000  # production steps. LIVE default 100000; the shipped reference uses 500000
variable seed    index 90187   # RNG seed for the initial velocities. The ensemble varies this per replica
variable dump    index 0       # -var dump 1 -> write slab_traj.xyz (production) for view_domain / intrinsic
variable localstress index 0   # -var localstress 1 -> also bin the diagonal pressure tensor for gamma
variable outdir  index .       # output directory (the ensemble sets one per replica)
shell mkdir ${outdir}

# ---- derived geometry (snap box to whole FCC lattice constants) ----
variable af    equal (4.0/v_rho_l)^(1.0/3.0)   # FCC lattice constant
variable Lx    equal round(v_Lx_t/v_af)*v_af
variable Ly    equal round(v_Ly_t/v_af)*v_af
variable Lz    equal round(v_Lz_t/v_af)*v_af
variable zlo_s equal round(0.5*(v_Lz-v_tslab))         # central slab band [zlo_s, zhi_s]
variable zhi_s equal round(0.5*(v_Lz+v_tslab))

# ---- system: long p p p box, ONE LJ type, central FCC slab + vapour on both sides ----
units           lj
atom_style      atomic
boundary        p p p
region sim block 0 ${Lx} 0 ${Ly} 0 ${Lz} units box
create_box 1 sim

# Liquid slab
lattice fcc ${rho_l}
region       liquid block INF INF INF INF ${zlo_s} ${zhi_s} units box
create_atoms 1 region liquid

# vapour on both sides (lower-density lattice, seeded at rho_v)
lattice      fcc ${rho_v}
region       vapbot block INF INF INF INF 0.0 ${zlo_s} units box
region       vaptop block INF INF INF INF ${zhi_s} ${Lz} units box
create_atoms 1 region vapbot
create_atoms 1 region vaptop

mass  1 1.0
group fluid type 1
pair_style lj/cut ${rcut}
pair_modify shift no tail no
pair_coeff 1 1 1.0 1.0 ${rcut}

neighbor 0.3 bin
neigh_modify delay 0 every 1 check yes
thermo ${nevery}
thermo_style custom step temp pe press pxx pyy pzz 

velocity all create ${T} ${seed} mom yes rot no dist gaussian


timestep ${dt}

# record the box + parameters for the analysis scripts
print "Lx $(lx)"      file   ${outdir}/slab_params.txt
print "Ly $(ly)"      append ${outdir}/slab_params.txt
print "Lz $(lz)"      append ${outdir}/slab_params.txt
print "tslab ${tslab}" append ${outdir}/slab_params.txt
print "rho_l ${rho_l}" append ${outdir}/slab_params.txt
print "rho_v ${rho_v}" append ${outdir}/slab_params.txt
print "rcut ${rcut}"   append ${outdir}/slab_params.txt
print "T ${T}"         append ${outdir}/slab_params.txt
print "seed ${seed}"   append ${outdir}/slab_params.txt
print "bin ${bin}"     append ${outdir}/slab_params.txt

# optional orientation trajectory for VMD/OVITO (production only; off by default, pass -var dump 1).
# element names are only for viewer colouring; the model is a generic LJ channel.
if "${dump} > 0" then &
  "dump dvmd all xyz 1000 ${outdir}/day2_traj.xyz" &
  "dump_modify dvmd element Ar sort id"

#Equilibration run
fix nvtall all nvt temp ${T} ${T} ${tdamp}
run ${nequil}
#reset_timestep 0
unfix nvtall

# ---- production observables (defined AFTER equilibration so they sample production only) ----
variable nb  equal round(v_Lz/v_bin)
variable dz  equal v_Lz/v_nb
variable nrep  equal floor(v_nprod/${nevery})        # ave/chunk: samples per block
variable nfreq equal ${nevery}*v_nrep                # averaging window (<= nprod for nprod >= 100)
compute cbinL fluid chunk/atom bin/1d z lower ${dz} units box

fix     frho fluid ave/chunk ${nevery} ${nrep} ${nfreq} cbinL density/number &
        file ${outdir}/day2_density.profile

if "${localstress} > 0" then &
  "compute virial fluid stress/atom NULL pair" &
  "compute kinetic fluid stress/atom NULL ke" &
  "fix     Pxy  fluid ave/chunk ${nevery} ${nrep} ${nfreq} cbinL c_virial[1] c_virial[2] c_virial[3] c_kinetic[1] c_kinetic[2] c_kinetic[3]  norm none file ${outdir}/day2_stress.profile"

#Production run
fix nve all nve
run ${nprod}
