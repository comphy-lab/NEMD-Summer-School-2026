# =====================================================================
#  NEMD Summer School 2026 - Day 2 hands-on  (Part 1: the slit-pore)
#  MEASUREMENT: local viscosity profile and the breakdown of Newton's law
#
#  Drive a confined LJ liquid with a body force along x (Poiseuille flow),
#  measure vx(z) and the mass density rho_m(z). The analyser forms
#     eta(z) = -P_xz(z) / (dvx/dz),   P_xz(z) = +g * integral_0^z rho_m dz'
#  (momentum balance from the centreline). `width` is the LITERAL pore width
#  in sigma (the setup displaces the top wall to set it exactly). A WIDE pore
#  (-var width 10) -> vx(z) a parabola and eta(z) a flat plateau near the
#  bulk shear viscosity. A NARROW pore (-var width 4) -> the density layers fill
#  the whole pore, P_xz(z) follows the layering, and eta(z) has no single
#  plateau: a local Newtonian viscosity no longer describes the liquid
#  (Travis, Todd & Evans, PRE 55, 4288).
#
#  Run FROM THIS FOLDER (so `include ../shared_setup.lmp` resolves):
#     ../submit.sh poiseuille.in                  (locally: lmp_serial -in poiseuille.in)
#     ../submit.sh poiseuille.in -var width 4     (the narrow-pore Push)
#  then: python analyse_poiseuille.py
# =====================================================================

# ---- case parameters (this measurement's settings; -var still overrides) ----
variable T      index 1.0       # single-phase dense-liquid temperature (T* = 1.0)
variable width  index 10        # TARGET inner-plane separation; Push: -var width 4
variable nequil index 100000    # equilibration steps
variable nprod  index 200000    # production steps (multiple of 100)

# clear this width's outputs at the start, so a re-run after an interrupted/failed run
# cannot leave stale poiseuille_w${width}.* for the analyser to read as this run's result.
# (submit.sh does this for the SLURM path; this also covers the bare `lmp_serial -in` path.)
shell rm -f poiseuille_w${width}.profile poiseuille_w${width}.params.txt poiseuille_w${width}.png poiseuille_w${width}_traj.xyz

include ./shared_setup.lmp

# =====================================================================
#  Body-force Poiseuille drive + the vx(z) / rho_m(z) measurement.
#  (mass = 1, so the per-atom force passed to addforce IS the per-mass g,
#   and rho_m = rho_N: no per-atom-force-vs-mass-density mismatch.)
# =====================================================================
variable gforce index 0.05      # per-atom body force along x; the wide pore stays Newtonian at this
#                                 force, and it lifts the narrow-pore signal above the noise.
#                                 The narrow Push changes ONLY -var width, so gforce is the same for both.
fix drive fluid addforce ${gforce} 0.0 0.0

run ${nequil}
reset_timestep 0

# vx(z) and mass density rho_m(z), binned fine across the pore. The wall
# bins contain no fluid (group = fluid), so those rows are 0; the analyser keeps
# only the fluid interval [z_bot_inner, z_top_inner] from the params file.
variable binw equal 0.1                                # velocity-profile bin width (sigma)
variable nvb  equal round(lz/v_binw)                   # key off the REAL box length lz (Lz is the pre-cap construction box)
variable dzv  equal lz/v_nvb
compute cvx fluid chunk/atom bin/1d z lower ${dzv} units box
fix     fvx fluid ave/chunk 100 ${nrep} ${nfreq} cvx vx density/mass file poiseuille_w${width}.profile

# geometry + drive written for the analyser, WIDTH-TAGGED so the w=10 and w=4
# datasets coexist for the wide-vs-narrow comparison at the end of the sheet.
print "Lz $(lz)"           file   poiseuille_w${width}.params.txt
print "wall_th ${wall_th}" append poiseuille_w${width}.params.txt
print "width ${width}"      append poiseuille_w${width}.params.txt
print "w_meas ${wmeas}"     append poiseuille_w${width}.params.txt
print "z_bot_inner ${zbi}" append poiseuille_w${width}.params.txt
print "z_top_inner ${zti}" append poiseuille_w${width}.params.txt
print "gforce ${gforce}"   append poiseuille_w${width}.params.txt
print "binw ${binw}"       append poiseuille_w${width}.params.txt

# optional orientation trajectory (production only; off by default, -var dump 1).
if "${dump} > 0" then &
  "dump dvmd all xyz 1000 poiseuille_w${width}_traj.xyz" &
  "dump_modify dvmd element Ar Cu Cu sort id"

run ${nprod}
print "Done. Analyse with:  python analyse_poiseuille.py"
